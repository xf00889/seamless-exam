# ============================================
# Offline Exam System - Environment Configuration
# ============================================
# This file contains configuration for local network deployment
# Copy this file to .env and update with your actual values

# Database Configuration (Requirement 18.3, 18.4, 1.4)
# MySQL database runs locally on teacher's laptop
# SECURITY: Use strong password and localhost-only access
DB_NAME=exam_system_db
DB_USER=exam_admin  # Use dedicated user instead of root for better security
DB_PASSWORD=your_strong_password_here  # REQUIRED: Use strong password (min 12 chars, mixed case, numbers, symbols)
DB_HOST=localhost  # SECURITY: Always localhost - no remote database access
DB_PORT=3306

# MySQL Security Notes (Requirement 1.4):
# 1. Create dedicated database user: CREATE USER 'exam_admin'@'localhost' IDENTIFIED BY 'strong_password';
# 2. Grant only necessary privileges: GRANT ALL PRIVILEGES ON exam_system_db.* TO 'exam_admin'@'localhost';
# 3. Use strong password: minimum 12 characters with uppercase, lowercase, numbers, and symbols
# 4. Bind MySQL to localhost only: edit my.cnf/my.ini and set bind-address = 127.0.0.1
# 5. Disable remote root access: DELETE FROM mysql.user WHERE User='root' AND Host NOT IN ('localhost', '127.0.0.1', '::1');

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here

# Security
CSRF_COOKIE_NAME=exammaker_csrftoken
SESSION_COOKIE_NAME=exammaker_sessionid

# File Upload
MAX_UPLOAD_SIZE=52428800  # 50MB
MAX_IMAGE_SIZE=5242880    # 5MB

# Local Network Configuration (Requirement 18.1, 18.2, 18.5)
# The server will bind to 0.0.0.0:8000 to accept connections from local network
# Students connect via: http://<teacher-ip>:8000
# Example: http://192.168.137.1:8000 (Windows hotspot default)
# Example: http://192.168.2.1:8000 (macOS/Linux hotspot typical)
